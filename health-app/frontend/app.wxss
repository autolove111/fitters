page {
  background: linear-gradient(180deg, #f4f7f5 0%, #e8f1ec 100%);
  color: #1f2937;
  font-size: 28rpx;
}

.container {
  padding: 28rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(27, 67, 50, 0.08);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.input {
  border: 1rpx solid #d7e1dc;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  background: #fbfdfc;
}

.btn {
  margin-top: 10rpx;
  background: #2d6a4f;
  color: #fff;
}

.sub {
  color: #4b5563;
  font-size: 24rpx;
}
