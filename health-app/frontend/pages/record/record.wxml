<view class="container">
  <view class="card">
    <view class="title">运动记录</view>
    <input class="input" placeholder="运动类型(跑步/步行)" value="{{sportType}}" bindinput="onSportType" />
    <input class="input" placeholder="时长(分钟)" type="number" value="{{durationMin}}" bindinput="onDuration" />
    <input class="input" placeholder="消耗(kcal)" type="number" value="{{sportCalories}}" bindinput="onSportCalories" />
    <button class="btn" bindtap="recordSport">提交运动</button>
  </view>

  <view class="card">
    <view class="title">睡眠记录</view>
    <input class="input" placeholder="睡眠时长(小时)" type="number" value="{{sleepHours}}" bindinput="onSleepHours" />
    <input class="input" placeholder="深睡比例(0~1)" type="digit" value="{{deepSleepRatio}}" bindinput="onDeepSleepRatio" />
    <button class="btn" bindtap="recordSleep">提交睡眠</button>
  </view>

  <view class="card">
    <view class="title">饮食记录</view>
    <input class="input" placeholder="食物名称" value="{{foodName}}" bindinput="onFoodName" />
    <input class="input" placeholder="热量(kcal)" type="number" value="{{dietCalories}}" bindinput="onDietCalories" />
    <button class="btn" bindtap="recordDiet">提交饮食</button>
  </view>
</view>
