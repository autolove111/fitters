<view class="container">
  <view class="card">
    <view class="title">智能饮食推荐</view>
    <button class="btn" bindtap="loadRecommendation">获取推荐</button>
    <view class="sub">{{recommendText}}</view>
  </view>

  <view class="card">
    <view class="title">每日报告</view>
    <button class="btn" bindtap="loadDailyReport">获取报告</button>
    <view class="sub">{{reportText}}</view>
  </view>
</view>
